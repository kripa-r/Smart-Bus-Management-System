# App Environment
FLASK_ENV=development
SECRET_KEY=replace-with-strong-random-secret-key
PORT=5000

# Preferred production DB (Render/Railway/PlanetScale)
DATABASE_URL=mysql+pymysql://user:password@host:3306/smart_bus_db

# Local MySQL fallback (used when DATABASE_URL is not set)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DB=smart_bus_db

# Flask-Mail (OTP in production)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-16-char-app-password
MAIL_USE_TLS=True
MAIL_USE_SSL=False
MAIL_DEFAULT_SENDER=your-email@gmail.com

# Upload Configuration
UPLOAD_FOLDER=uploads/mileage
ALLOWED_EXTENSIONS=png,jpg,jpeg,gif,pdf
MAX_CONTENT_LENGTH=5242880

# Session Security
SESSION_COOKIE_SECURE=False
SESSION_COOKIE_SAMESITE=Lax
PERMANENT_SESSION_LIFETIME_SECONDS=7200

# CORS for API routes
CORS_ORIGINS=*

# IoT Bus Arrival Detection
BUS_ARRIVAL_CUTOFF_HOUR=9
BUS_ARRIVAL_CUTOFF_MINUTE=10
BUS_ARRIVAL_DEBOUNCE_SECONDS=15
